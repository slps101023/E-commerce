# ======================================
# Backend (server/index.js)
# Copy this file to .env and fill values
# ======================================

# Backend listening port
PORT=5000

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:5432/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce

# JWT signing secret (use a long random string in production)
JWT_KEY=change_this_to_a_strong_secret

# bcrypt salt rounds (10-12 is common)
SALT_ROUNDS=10

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# ======================================
# Frontend (optional for local frontend dev)
# If you run frontend outside Docker, set this in frontend/.env.local
# ======================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api
